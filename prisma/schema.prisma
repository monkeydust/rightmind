// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Models ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  openRouterKey   String?   // BYOK — encrypted per-user OpenRouter API key
  emailOnComplete Boolean   @default(false) // Send email when job finishes
  accounts      Account[]
  sessions      Session[]
  jobs          AdvisorJob[]
  apiKeys       ApiKey[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ─────────────────────────────────────

model AdvisorJob {
  id            String   @id @default(uuid())
  userId        String?  // Links job to user (nullable for migration)
  user          User?    @relation(fields: [userId], references: [id])
  challenge     String   // The user's input challenge text
  fileName      String?  // Original filename if a file was uploaded (e.g. "business-plan.pdf")
  strategyId    String   // Maps to strategy config id (e.g. "consensus-board")
  executionMode String   @default("instant") // "instant" or "overnight"
  status        String   @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  progress      String   @default("[]") // JSON array of step completions
  report        String?  // Final markdown report (null until complete)
  error         String?  // Error message if status = FAILED
  parentJobId   String?  // For all-angles: links child strategy jobs to the parent
  webhookUrl    String?  // URL to POST to when job completes
  webhookSecret String?  // Optional secret to HMAC sign the webhook payload
  totalCostUsd  Float    @default(0) // Total cost in USD for all LLM calls in this job
  totalTokens   Int      @default(0) // Total tokens used across all LLM calls
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?

  // Individual agent responses stored for debug/transparency
  agentResponses AgentResponse[]
  followUps      JobFollowUp[]
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    // Human-readable label (e.g. "OpenClaw production")
  keyHash     String    @unique // SHA-256 hash of the full key
  prefix      String    // First 8 chars of the key for identification (e.g. "rm_live_a1b2c3d4")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model AgentResponse {
  id               String   @id @default(uuid())
  jobId            String
  job              AdvisorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  agentRole        String   // e.g. "Risk Analyst", "Devil's Advocate"
  agentModel       String   // e.g. "anthropic/claude-opus-4-7"
  round            Int      @default(1) // Which round of the workflow
  phase            String?  // e.g. "draft", "critique", "refine" (for sequential strategies)
  prompt           String   // The full prompt sent to the model
  response         String   // The model's response
  reasoning        String?  // The model's thinking/reasoning trace (if requested)
  tokens           Int      @default(0) // Total tokens used
  promptTokens     Int      @default(0) // Input tokens
  completionTokens Int      @default(0) // Output tokens
  costUsd          Float    @default(0) // Cost in USD for this call (from OpenRouter)
  durationMs       Int      @default(0) // How long the call took
  createdAt        DateTime @default(now())
}

model JobFollowUp {
  id         String     @id @default(uuid())
  jobId      String
  job        AdvisorJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  turnNumber Int
  prompt     String     // The user's follow-up question
  response   String     // The model's response (markdown)
  model      String     // Which model was used
  tokens     Int        @default(0)
  costUsd    Float      @default(0) // Cost in USD for this follow-up call
  durationMs Int        @default(0)
  createdAt  DateTime   @default(now())
}

